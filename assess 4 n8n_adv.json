    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    record_id,\n    profile_url,\n    normalized_instagram_url,\n    full_name,\n    email,\n    phone,\n    followers,\n    status,\n    created_at\nFROM influencers_raw\nWHERE normalized_instagram_url = 'https://www.instagram.com/your_target_handle/'\n  AND status = 'S1'\nORDER BY created_at ASC;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1296,
        64
      ],
      "id": "1f67d573-c14c-408b-999a-bce8ddc42ce4",
      "name": "Fetch Full Duplicate Groups",
      "credentials": {
        "postgres": {
          "id": "Pz5LiQSqb8EQE2AD",
          "name": "Postgres account"
        }
      }
