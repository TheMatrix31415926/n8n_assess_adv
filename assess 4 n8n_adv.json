    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst groups = {};\n\n// Group all records by normalized URL\nfor (const item of items) {\n  const url = item.json.normalized_instagram_url;\n  if (!groups[url]) groups[url] = [];\n  groups[url].push(item.json);\n}\n\nconst primaryRecords = [];\nconst duplicateMarkers = [];\n\nfor (const [url, records] of Object.entries(groups)) {\n  // Sort oldest first - oldest becomes primary\n  records.sort((a, b) => new Date(a.created_at) - new Date(b.created_at));\n\n  const primary = records[0];\n  const duplicates = records.slice(1);\n\n  // Merge: pick first non-null value from all records\n  const merged = {\n    record_id: primary.record_id,\n    normalized_instagram_url: url,\n    profile_url: primary.profile_url,\n    full_name: null,\n    email: null,\n    phone: null,\n    followers: null\n  };\n\n  for (const r of records) {\n    if (!merged.full_name && r.full_name) merged.full_name = r.full_name;\n    if (!merged.email && r.email) merged.email = r.email;\n    if (!merged.phone && r.phone) merged.phone = r.phone;\n    if (!merged.followers && r.followers) merged.followers = r.followers;\n  }\n\n  primaryRecords.push({\n    json: { ...merged, status: 'CRM_Pending', is_primary: true }\n  });\n\n  for (const dup of duplicates) {\n    duplicateMarkers.push({\n      json: {\n        record_id: dup.record_id,\n        merged_into: primary.record_id,\n        status: 'merged'\n      }\n    });\n  }\n}\n\n// Store in workflow static data for use in next nodes\n$workflow.staticData.primaryRecords = primaryRecords;\n$workflow.staticData.duplicateMarkers = duplicateMarkers;\n\n// Return primary records first\nreturn primaryRecords.length > 0 ? primaryRecords : [{ json: { no_merges: true } }];"
      },
