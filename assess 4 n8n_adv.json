    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json;\n  let normalizedUrl = null;\n\n  if (data.profile_url) {\n    // Step 1: lowercase and trim\n    let url = data.profile_url.toLowerCase().trim();\n\n    // Step 2: remove http/https and www\n    url = url.replace(/^https?:\\/\\/(www\\.)?/, '');\n\n    // Step 3: remove trailing slash\n    url = url.replace(/\\/$/, '');\n\n    // Step 4: extract instagram.com/username\n    const match = url.match(/instagram\\.com\\/([a-z0-9._]+)/);\n\n    if (match) {\n      normalizedUrl = `instagram.com/${match[1]}`;\n    }\n  }\n\n  results.push({\n    json: {\n      ...data,\n      normalized_instagram_url: normalizedUrl\n    }\n  });\n}\n\nreturn results;"
      },
