    {
      "parameters": {
        "jsCode": "const person = $json;\n\n// Extract profile details\nconst name = person.name;\nconst headline = person.headline;\n\nreturn {\n  json: {\n    ...person,\n    prompt: `You are a professional LinkedIn networking assistant.\n    Write a personalized connection request note (max 200 characters).\n\n    Target: ${name}\n    Headline: \"${headline}\"\n\n    Rules:\n    - Mention something specific from their headline to show you read it.\n    - Be professional, concise, and helpful.\n    - Do NOT use emojis.\n    - Do NOT use generic \"I'd like to add you\" phrasing.\n    - Focus on the fact that you share an interest in AI Automation.\n\n    Write ONLY the connection note text, nothing else.`\n  }\n};"
      },
