      "parameters": {
        "jsCode": "const inputData = $input.all();\n\n// 1. Extract the list of people from the API response\n// The API returns an object containing an 'items' array\nlet people = [];\nif (inputData.length > 0 && inputData[0].json && inputData[0].json.items) {\n  people = inputData[0].json.items;\n}\n\n// 2. Define Filter Rules for Profiles\n// Example: Keep only people who have \"Automation\" in their headline\nconst KEYWORD = \"automation\"; \n\nconst filtered = people.filter(person => {\n  const headline = (person.headline || \"\").toLowerCase();\n  \n  // Rule: Check if the person's headline contains the keyword\n  if (!headline.includes(KEYWORD.toLowerCase())) return false;\n  \n  return true;\n});\n\n// 3. Map the results to a clean format\nreturn filtered.map(person => ({\n  json: {\n    name: person.name,\n    headline: person.headline,\n    location: person.location,\n    profile_url: person.profile_url,\n    filter_passed: true\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
