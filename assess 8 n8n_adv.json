        "jsCode": "// Access the correct nested path shown in your output logs\nconst rawText = items[0].json.generations?.[0]?.[0]?.text;\n\n// Safety check: if rawText is missing, return the whole object to debug\nif (!rawText) {\n  return { json: { error: \"Could not find text\", fullData: items[0].json } };\n}\n\n// Regex to extract JSON\nconst jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\n\nif (jsonMatch) {\n  try {\n    const parsedJson = JSON.parse(jsonMatch[0]);\n    return { json: parsedJson };\n  } catch (e) {\n    return { json: { error: \"Failed to parse JSON\", raw: rawText } };\n  }\n} else {\n  return { json: { error: \"No JSON found in output\", raw: rawText } };\n}"
      },
