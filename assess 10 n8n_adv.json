    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const original = item.json;\n  let rawOutput = item.json.output || '';\n  let tasks = [];\n\n  try {\n    if (typeof rawOutput === 'string') {\n      rawOutput = rawOutput\n        .replace(/```json/gi, '')\n        .replace(/```/g, '')\n        .trim();\n\n      const start = rawOutput.indexOf('[');\n      const end = rawOutput.lastIndexOf(']');\n\n      if (start !== -1 && end !== -1) {\n        tasks = JSON.parse(\n          rawOutput.substring(start, end + 1)\n        );\n      }\n    } else if (Array.isArray(rawOutput)) {\n      tasks = rawOutput;\n    }\n  } catch(e) {\n    tasks = [];\n  }\n\n  const validCategories = [\n    'Content','SEO','Social','Paid','Email','Brand'\n  ];\n  const validPriorities = ['High','Medium','Low'];\n\n  return tasks.map(task => {\n\n    let category = (task.category || 'Content').trim();\n    if (!validCategories.includes(category)) {\n      category = 'Content';\n    }\n\n    let priority = (task.priority || 'Medium').trim();\n    if (!validPriorities.includes(priority)) {\n      priority = 'Medium';\n    }\n\n    let iceScore = parseInt(task.ice_score) || 50;\n    iceScore = Math.min(100, Math.max(1, iceScore));\n\n    let dueDays = parseInt(task.due_days) || 14;\n    dueDays = Math.min(90, Math.max(7, dueDays));\n\n    return {\n      json: {\n        record_id: original.record_id,\n        task_title: (task.task_title || '').substring(0, 200),\n        rationale: (task.rationale || '').substring(0, 300),\n        category: category,\n        priority: priority,\n        ice_score: iceScore,\n        owner_role: task.owner_role || 'Marketing Manager',\n        due_days: dueDays,\n        source_insight: (task.source_insight || '').substring(0, 200),\n        competitor: original.competitor_name,\n        timestamp: new Date().toISOString()\n      }\n    };\n  });\n\n}).flat();"
      },
