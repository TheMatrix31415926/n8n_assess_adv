    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze these competitor LinkedIn posts for:\n{{ $json.competitor_name || $('Loop Over Items').first().json.competitor_name }}\n\nPosts data:\n{{ JSON.stringify($input.all().slice(0,5).map(i => ({\n  text: i.json.text || i.json.content || '',\n  likes: i.json.likesCount || 0,\n  comments: i.json.commentsCount || 0,\n  type: i.json.type || 'post'\n}))) }}\n\nReturn a JSON array of insights:\n[\n  {\n    \"post_topic\": \"Topic of the post\",\n    \"engagement_level\": \"High|Medium|Low\",\n    \"content_type\": \"Educational|Promotional|Story|News\",\n    \"key_insight\": \"What makes this post effective\",\n    \"likes\": 0,\n    \"comments\": 0\n  }\n]",
        "options": {
          "systemMessage": "You are a competitive intelligence analyst.\nAnalyze LinkedIn posts from competitors and \nextract structured insights.\nAlways respond with ONLY raw JSON array.\nNo markdown, no backticks.\nStart with [ and end with ]"
