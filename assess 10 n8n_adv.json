    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst original = $('Loop Over Items').first().json;\n\nlet rawOutput = item.json.output || '';\nlet insights = [];\n\ntry {\n  // Clean markdown\n  if (typeof rawOutput === 'string') {\n    rawOutput = rawOutput\n      .replace(/```json/gi, '')\n      .replace(/```/g, '')\n      .trim();\n\n    // Find JSON array\n    const start = rawOutput.indexOf('[');\n    const end = rawOutput.lastIndexOf(']');\n\n    if (start !== -1 && end !== -1) {\n      insights = JSON.parse(\n        rawOutput.substring(start, end + 1)\n      );\n    }\n  } else if (Array.isArray(rawOutput)) {\n    insights = rawOutput;\n  }\n} catch(e) {\n  // Safe fallback\n  insights = [{\n    post_topic: 'Parse Error',\n    engagement_level: 'Unknown',\n    content_type: 'Unknown',\n    key_insight: 'Failed to parse: ' + e.message,\n    likes: 0,\n    comments: 0\n  }];\n}\n\n// Validate + normalize each insight\nconst validEngagement = ['High', 'Medium', 'Low'];\nconst validTypes = [\n  'Educational', 'Promotional', \n  'Story', 'News'\n];\n\nconst analysisRows = insights.map((insight, i) => {\n\n  let engagement = (insight.engagement_level || 'Low')\n    .trim();\n  if (!validEngagement.includes(engagement)) {\n    engagement = 'Medium';\n  }\n\n  let contentType = (insight.content_type || 'News')\n    .trim();\n  if (!validTypes.includes(contentType)) {\n    contentType = 'News';\n  }\n\n  return {\n    record_id: original.record_id,\n    competitor_name: original.competitor_name,\n    post_topic: (insight.post_topic || '')\n      .substring(0, 200),\n    engagement_level: engagement,\n    content_type: contentType,\n    key_insight: (insight.key_insight || '')\n      .substring(0, 300),\n    likes: parseInt(insight.likes) || 0,\n    comments: parseInt(insight.comments) || 0,\n    timestamp: new Date().toISOString()\n  };\n});\n\n// Pass both analysis rows AND original context\nreturn [{\n  json: {\n    record_id: original.record_id,\n    competitor_name: original.competitor_name,\n    linkedin_url: original.linkedin_url,\n    analysis_rows: analysisRows,\n    analysis_count: analysisRows.length,\n    analysis_summary: analysisRows\n      .map(r => `${r.post_topic}: ${r.engagement_level}`)\n      .join(' | '),\n    parse_success: insights.length > 0\n  }\n}];"
      },
