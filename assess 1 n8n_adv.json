    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    p.*,\n    s.session_cookie,\n    s.is_valid as cookie_valid\nFROM post_call_records p\nLEFT JOIN erp_session s \n    ON s.cookie_key = 'acumatica_session'\nWHERE p.call_id = '{{ $json.body.call_id }}'\nAND p.processed = FALSE;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
