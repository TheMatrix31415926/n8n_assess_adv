    {
      "parameters": {
        "jsCode": "const loginResponse = $input.first().json;\nconst originalData = $('Code - Clean Call Data')\n  .first().json;\n\n// Parse fresh cookie from login response\n// In real Acumatica this comes from Set-Cookie header\nconst freshCookie = loginResponse.headers\n  ? loginResponse.headers['set-cookie'] || \n    'ASP.NET_SessionId=fresh-cookie-' + Date.now()\n  : 'ASP.NET_SessionId=fresh-cookie-' + Date.now();\n\nreturn [{\n  json: {\n    ...originalData,\n    session_cookie: freshCookie,\n    cookie_refreshed: true,\n    refresh_timestamp: new Date().toISOString()\n  }\n}];"
      },
