    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst d = item.json;\n\n// Webhook data\nconst webhookData = $('Webhook - Retell Post Call')\n  .first().json;\n\n// Disposition mapping table\n// Natural language → ERP code\nconst dispositionMap = {\n  // Positive outcomes\n  'interested':           'DISP-001-HOT',\n  'very_interested':      'DISP-001-HOT',\n  'ready_to_buy':         'DISP-001-HOT',\n  'demo_requested':       'DISP-002-WARM',\n  'callback_requested':   'DISP-002-WARM',\n  'follow_up_needed':     'DISP-002-WARM',\n  'pricing_requested':    'DISP-002-WARM',\n  // Neutral outcomes\n  'voicemail':            'DISP-003-COLD',\n  'no_answer':            'DISP-003-COLD',\n  'left_message':         'DISP-003-COLD',\n  'busy':                 'DISP-003-COLD',\n  // Negative outcomes\n  'not_interested':       'DISP-004-DEAD',\n  'do_not_call':          'DISP-005-DNC',\n  'wrong_number':         'DISP-006-INVALID',\n  'disconnected':         'DISP-006-INVALID'\n};\n\n// Normalize outcome to lowercase\nconst outcome = (\n  webhookData.outcome || \n  d.outcome || ''\n).toLowerCase().trim()\n  .replace(/\\s+/g, '_');\n\n// Map to ERP disposition code\nconst dispositionCode = \n  dispositionMap[outcome] || 'DISP-099-UNKNOWN';\n\n// Normalize agent notes\nconst agentNotes = (\n  webhookData.agent_notes || \n  d.agent_notes || ''\n).trim().substring(0, 500);\n\nreturn [{\n  json: {\n    call_id: webhookData.call_id || d.call_id,\n    customer_id: webhookData.customer_id || \n                 d.customer_id,\n    outcome: outcome,\n    disposition_code: dispositionCode,\n    agent_notes: agentNotes,\n    session_cookie: d.session_cookie || '',\n    cookie_valid: d.cookie_valid || false,\n    // ERP payload formatted for Acumatica\n    erp_payload: {\n      CustomerID: { \n        value: webhookData.customer_id || \n               d.customer_id \n      },\n      CallID: { value: webhookData.call_id },\n      Disposition: { value: dispositionCode },\n      Notes: { value: agentNotes },\n      Status: { value: 'Processed' }\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        576,
        -16
      ],
      "id": "420b47f7-69c6-4320-8014-c2f7ec88186d",
      "name": "Code in JavaScript5"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Find the item with disposition_code\n// (from Code JS5 stream)\nconst callData = items.find(\n  item => item.json.disposition_code\n) || items[0];\n\nconst d = callData.json;\n\n// Validate all required ERP fields\nconst missing = [];\nif (!d.call_id) missing.push('call_id');\nif (!d.customer_id) missing.push('customer_id');\nif (!d.disposition_code) \n  missing.push('disposition_code');\n\nif (missing.length > 0) {\n  throw new Error(\n    'Missing required fields: ' + missing.join(', ')\n  );\n}\n\n// Get session cookie\nconst cookie = d.session_cookie || \n  'ASP.NET_SessionId=demo-cookie-001';\n\nreturn [{\n  json: {\n    ...d,\n    session_cookie: cookie,\n    cookie_header: `Cookie: ${cookie}`,\n    cleaned_at: new Date().toISOString()\n  }\n}];"
      },
