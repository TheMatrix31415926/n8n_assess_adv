    {
      "parameters": {
        "jsCode": "const data = $json;\n\n// Skip if previous step had error\nif (data.error) {\n  return {\n    json: {\n      ...data,\n      engagement_tier: 'unknown',\n      account_type: 'unknown',\n      status: 'failed'\n    }\n  };\n}\n\n// Classify engagement tier\nlet engagementTier = 'nano';\nif (data.followers > 1000000) engagementTier = 'mega';\nelse if (data.followers > 100000) engagementTier = 'macro';\nelse if (data.followers > 10000) engagementTier = 'micro';\nelse if (data.followers > 1000) engagementTier = 'nano';\n\n// Classify account type\nlet accountType = 'personal';\nif (data.is_verified) accountType = 'verified_brand';\nelse if (data.followers > 10000) accountType = 'business';\n\nreturn {\n  json: {\n    competitor_name: data.competitor_name,\n    instagram_handle: data.instagram_handle,\n    full_name: data.full_name,\n    followers: data.followers,\n    following: data.following,\n    posts_count: data.posts_count,\n    bio: data.bio,\n    external_url: data.external_url,\n    is_verified: data.is_verified,\n    engagement_tier: engagementTier,\n    account_type: accountType,\n    scraped_at: data.scraped_at,\n    status: 'success'\n  }\n};"
      },
