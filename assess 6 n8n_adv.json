      "parameters": {
        "jsCode": "const data = $json;\n\n// Handle case where Apify returned error or empty\nif (!data || Object.keys(data).length === 0) {\n  return {\n    json: {\n      error: true,\n      message: 'No Instagram data returned',\n      instagram_handle: $('Loop Over Items').item.json.instagram_handle,\n      scraped_at: new Date().toISOString()\n    }\n  };\n}\n\n// Flatten the Instagram profile data\nreturn {\n  json: {\n    competitor_name: $('Loop Over Items').item.json.competitor_name,\n    instagram_handle: data.username || $('Loop Over Items').item.json.instagram_handle,\n    full_name: data.fullName || '',\n    bio: data.biography || '',\n    followers: data.followersCount || 0,\n    following: data.followsCount || 0,\n    posts_count: data.postsCount || 0,\n    is_verified: data.verified || false,\n    profile_url: `https://instagram.com/${data.username || ''}`,\n    external_url: data.externalUrl || '',\n    scraped_at: new Date().toISOString(),\n    error: false\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
